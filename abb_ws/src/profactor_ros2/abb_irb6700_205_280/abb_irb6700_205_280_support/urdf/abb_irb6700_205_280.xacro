  <xacro:amura_gripper prefix=""/> -->


  <!-- ros2_control -->
  <xacro:include filename="$(find abb_irb6700_205_280_support)/urdf/abb_irb6700_205_280.ros2_control.xacro" />
  <!-- name="ABBMultiInterfaceHardware" -->
  <xacro:abb_ros2_control
    name="abb_irb6700_205_280_hw"
    prefix=""
    use_fake_hardware="${use_fake_hardware}"
    rws_ip="${rws_ip}"
    rws_port="${rws_port}"/>
</robot>